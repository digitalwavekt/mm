{
  "functions": {
    "api/[...path].ts": {
      "includeFiles": [
        "server/**",
        "db/**",
        "contracts/**"
      ]
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}