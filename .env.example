# Postgres connection string (e.g. Supabase / Neon / Render Postgres).
# Use the "pooled"/pgbouncer connection string if your provider offers one —
# this app runs as serverless functions on Vercel, and each invocation opens
# its own connection.
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Secret used to sign session/auth JWTs. Generate with: openssl rand -hex 32
JWT_SECRET=

# Bootstrap admin account created automatically on first boot if it doesn't
# exist yet. Log in at /admin with these credentials, then rotate them.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me

# Email (Resend) — used for contact form notifications.
RESEND_API_KEY=
EMAIL_FROM=onboarding@resend.dev
NOTIFY_EMAIL=
